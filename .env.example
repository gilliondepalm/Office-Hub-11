# =============================================================================
# Office Hub — voorbeeld omgevingsvariabelen
# Kopieer naar `.env` voor lokaal of gebruik als referentie voor je host.
# =============================================================================

# ------ Database ------
# PostgreSQL connection string. Verplicht.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/officehub

# ------ API server ------
# Poort waarop de API luistert. (Render/Fly/Railway zetten dit zelf.)
PORT=8080

# Lange willekeurige string. Verplicht in productie.
# Genereer met: openssl rand -hex 32
SESSION_SECRET=

# Komma-gescheiden lijst van toegestane origins voor CORS.
# Voorbeeld: https://office-hub.example.com,https://app.example.com
# Indien leeg: alle origins toegestaan (alleen voor development!).
CORS_ALLOWED_ORIGINS=

# Eerste admin-wachtwoord (wordt alleen gebruikt bij een leeg gebruikers-tabel).
# Indien niet ingesteld in productie, wordt een willekeurig wachtwoord
# gegenereerd en eenmalig in de logs getoond. De admin moet dit bij de
# eerste login direct wijzigen (must_change_password = true).
ADMIN_INITIAL_PASSWORD=

# Optioneel: zet de API server zo in dat deze ook de gebouwde web-app dient
# vanuit één service (handig voor Render/Fly/Heroku-achtige hosts).
# Pad relatief aan de werkmap (cwd) of absoluut.
SERVE_WEB_DIR=artifacts/office-hub/dist/public

# Marker voor productie-omgeving.
NODE_ENV=production

# ------ Web (Vite) ------
# Optioneel: alleen nodig als je de web-app onder een sub-pad host.
# Standaard "/".
BASE_PATH=/

# ------ Mobile (Expo / EAS) ------
# Volledige API URL die de gebouwde mobiele app gebruikt.
# Voorbeeld: https://api.office-hub.example.com
# Heeft prioriteit boven `expo.extra.apiUrl` in app.json.
EXPO_PUBLIC_API_URL=

# ------ Object storage (optioneel — anders lokale schijf) ------
# Stel S3_BUCKET in om object storage te activeren. Werkt met AWS S3,
# Cloudflare R2, Backblaze B2 en MinIO. Zonder S3_BUCKET schrijft de
# server uploads naar `<cwd>/uploads/` (vereist een persistente schijf
# op de host). Zie DEPLOY.md sectie 3 en 7 voor provider-voorbeelden.
S3_BUCKET=
S3_REGION=auto
# Endpoint alleen nodig voor niet-AWS providers (R2/B2/MinIO).
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Zet op "true" voor MinIO en sommige self-hosted providers.
S3_FORCE_PATH_STYLE=
# Optioneel: als de bucket publiek is, redirect /uploads/* hierheen
# (anders gebruikt de server presigned URLs).
S3_PUBLIC_BASE_URL=
# Levensduur (in seconden) van presigned URLs voor private buckets.
S3_PRESIGN_TTL_SECONDS=3600
